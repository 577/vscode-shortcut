{
  "name": "shortcut-menu-bar",
  "displayName": "Shortcut Menu Bar",
  "description": "Add handy buttons like beautify, show opened files, save, toggle terminal, activity bar etc to editor menu bar. User-defined buttons are also possible.",
  "version": "3.0.5",
  "publisher": "jerrygoyal",
  "author": {
    "name": "Gourav Goyal"
  },
  "engines": {
    "vscode": "^1.65.0"
  },
  "license": "GPL-3.0-or-later",
  "icon": "images/menubar.png",
  "galleryBanner": {
    "color": "#752d00",
    "theme": "dark"
  },
  "bugs": {
    "url": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension/issues",
    "email": "hey@gourav.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension.git"
  },
  "homepage": "https://github.com/GorvGoyl/Shortcut-Menu-Bar-VSCode-Extension",
  "categories": [
    "Programming Languages",
    "Other",
    "Visualization"
  ],
  "keywords": [
    "shortcut",
    "toolbar",
    "shortcuts",
    "menu",
    "menubar",
    "tool",
    "status",
    "editor",
    "bar",
    "shortcut menu bar",
    "button"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Shortcut Menu Bar",
      "properties": {}
    },
    "commands": [
      {
        "command": "ShortcutMenuBar.navigateBack",
        "title": "Go Back",
        "category": "ShortcutMenuBar",
        "icon": "$(arrow-left)"
      },
      {
        "command": "ShortcutMenuBar.navigateForward",
        "title": "Go Forward",
        "category": "ShortcutMenuBar",
        "icon": "$(arrow-right)"
      },
      {
        "command": "ShortcutMenuBar.format",
        "title": "Format",
        "category": "ShortcutMenuBar",
        "icon": "$(wand)"
      },
      {
        "command": "ShortcutMenuBar.toggleTerminalOn",
        "title": "Toggle Terminal",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-panel-off)"
      },
      {
        "command": "ShortcutMenuBar.toggleTerminalOff",
        "title": "Toggle Terminal",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-panel)"
      },
      {
        "command": "ShortcutMenuBar.togglePrimarySideBarOn",
        "title": "Toggle Primary Side Bar",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-sidebar-left-off)"
      },
      {
        "command": "ShortcutMenuBar.togglePrimarySideBarOff",
        "title": "Toggle Primary Side Bar",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "ShortcutMenuBar.toggleSecondarySideBarOn",
        "title": "Toggle Secondary Side Bar",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-sidebar-right-off)"
      },
      {
        "command": "ShortcutMenuBar.toggleSecondarySideBarOff",
        "title": "Toggle Secondary Side Bar",
        "category": "ShortcutMenuBar",
        "icon": "$(layout-sidebar-right)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ShortcutMenuBar.navigateBack",
          "group": "navigation@1"
        },
        {
          "command": "ShortcutMenuBar.navigateForward",
          "group": "navigation@2"
        },
        {
          "when": "editorHasDocumentFormattingProvider && editorTextFocus && !editorReadonly && !inCompositeEditor",
          "command": "ShortcutMenuBar.format",
          "group": "navigation@3"
        },
        {
          "when": "!panelVisible",
          "command": "ShortcutMenuBar.toggleTerminalOn",
          "group": "navigation@5"
        },
        {
          "when": "panelVisible",
          "command": "ShortcutMenuBar.toggleTerminalOff",
          "group": "navigation@5"
        },
        {
          "when": "!sideBarVisible",
          "command": "ShortcutMenuBar.togglePrimarySideBarOn",
          "group": "navigation@4"
        },
        {
          "when": "sideBarVisible",
          "command": "ShortcutMenuBar.togglePrimarySideBarOff",
          "group": "navigation@4"
        },
        {
          "when": "!auxiliaryBarVisible",
          "command": "ShortcutMenuBar.toggleSecondarySideBarOn",
          "group": "navigation@6"
        },
        {
          "when": "auxiliaryBarVisible",
          "command": "ShortcutMenuBar.toggleSecondarySideBarOff",
          "group": "navigation@6"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "login": "vsce login jerrygoyal",
    "publish": "vsce publish",
    "package": "vsce package && codium --uninstall-extension jerrygoyal.shortcut-menu-bar 2>/dev/null || true && codium --install-extension shortcut-menu-bar-3.0.5.vsix"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/node": "^17.0.23",
    "@types/vscode": "^1.65.0",
    "@typescript-eslint/eslint-plugin": "^5.16.0",
    "@typescript-eslint/parser": "^5.16.0",
    "eslint": "^8.12.0",
    "glob": "^7.2.0",
    "typescript": "^4.6.3",
    "vsce": "^2.7.0"
  }
}
